# yamllint config ŌĆö relax the defaults for the standards template family.
# Reasoning: the template ships heavily-commented YAML (lefthook.yml, .github/workflows/standards.yml)
# whose comments cross 80 chars to remain readable. document-start (---) is not part of the
# org YAML style. Comments min-spaces relaxed so trailing comments like `run: cmd # note` pass.
#
# WHAT THIS FILE IS: the template-shipped yamllint "floor" body. It renders
# into the consumer as `.yamllint.fragment` (NOT `.yamllint`). Pattern F ŌĆö
# sidecar fragment, mirrors `template/.gitignore.fragment.jinja`.
#
# MERGE PIPELINE: `scripts/merge-yamllint.sh` runs as a Copier `_tasks` hook
# after every render. It reads `.yamllint.fragment` + the consumer's optional
# `.yamllint.local`, deep-merges them via `yq *+` (mappings recurse, arrays
# append, ignore list deduped), writes the result to `.yamllint`, and unlinks
# the fragment. `.yamllint` is listed in `_skip_if_exists`, so copier's
# `_apply_update` diff-apply pass cannot touch it ŌĆö the hook is the sole
# writer of `.yamllint`. There is never a persisted `.yamllint.fragment` in
# a consumer repo.
#
# CONSUMER EXTENSIONS: create a `.yamllint.local` file in the repo root with
# your additional rules / ignores. Example:
#
#   # .yamllint.local
#   ignore:
#     - src/data/**          # content YAML, not infra
#     - vendor/**
#   rules:
#     line-length:
#       max: 200             # override template's 120
#
# After `copier copy/update`, the rendered `.yamllint` has both this floor's
# universal rules and your additions. The merge is idempotent and arrays
# concat with dedup, so re-running is safe. The rendered `.yamllint` is
# regenerated on every `copier update` ŌĆö hand edits there will not survive;
# move them into `.yamllint.local`. See MIGRATION.md "Pattern F ŌĆö sidecar
# managed file" for the consumer-facing migration story.
extends: default
# Ignores list. List form (not multi-line string) so the `_tasks`
# merge-yamllint.sh hook can deep-merge this fragment with `.yamllint.local`
# via `yq *+` (recursive merge of mappings; arrays append) when producing
# the final `.yamllint`. Consumers add their own paths in .yamllint.local ŌĆö
# the hook concatenates them onto this list at each copier update, preserving
# floor additions and consumer additions both. The hook also dedupes the
# result so re-runs are idempotent.
#
# `.copier-answers.yml` is generated by Copier's `to_nice_yaml` filter, whose
# sequence indentation doesn't match yamllint's default `indent-sequences: true`.
# Auto-managed ŌĆö humans should never edit it ŌĆö so policing its style is wasted
# cycles.
#
# Lockfiles (pnpm-lock.yaml, yarn.lock, package-lock.json, Cargo.lock, uv.lock,
# poetry.lock, go.sum, bun.lock, bun.lockb) are machine-generated and routinely
# violate yamllint's line-length rule with multi-hundred-character integrity
# hashes and resolved-URL fields. Linting their style buys nothing: the package
# manager (pnpm, yarn, cargo, uv, poetry, go, bun) is the authoritative writer,
# and lockfile integrity hashes already enforce correctness end-to-end. Every
# TS/Py/Rust/Go consumer hit hundreds of bogus line-length failures running
# `lefthook run pre-commit --all-files` before this exclusion was universal.
# Added in template/v1.2.8 from the vibe-kanban Pattern E migration.
ignore:
  - .copier-answers.yml
  - pnpm-lock.yaml
  - package-lock.json
  - yarn.lock
  - Cargo.lock
  - uv.lock
  - poetry.lock
  - go.sum
  - bun.lock
  - bun.lockb

rules:
  line-length:
    max: 120
  document-start: disable
  comments:
    min-spaces-from-content: 1
  # The template ships GitHub Actions `on:` keys (yamllint parses `on` as truthy
  # under YAML 1.1) and `with: { mode: gitleaks }` flow-style braces in
  # standards.yml. Jinja-padding blank lines appear between hook blocks in
  # rendered lefthook.yml output. Relax these universally so the template's own
  # YAML and every consumer's rendered output pass without per-repo tuning.
  truthy:
    check-keys: false
  braces:
    max-spaces-inside: 1
  empty-lines:
    max: 4
